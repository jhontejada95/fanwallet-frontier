# ── World ID (frontend) ──────────────────────────────────────────────────────
# Create your app at https://developer.worldcoin.org
# Use a "staging" environment app_id for testing with the World ID Simulator
# Switch to a production app_id before mainnet launch
VITE_WORLDID_APP_ID=app_staging_your_app_id_here

# ── World ID RP (backend — Vercel server-side only, NOT VITE_ prefixed) ──────
# Register an RP at developer.worldcoin.org → your app → Relying Parties
# These are server-side only — never expose them to the frontend
WORLDID_RP_ID=rp_your_rp_id_here
WORLDID_RP_SIGNING_KEY=your_hex_private_key_here
